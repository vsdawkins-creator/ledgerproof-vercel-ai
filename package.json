{
  "name": "@ledgerproof/vercel-ai",
  "version": "1.0.2",
  "description": "Vercel AI SDK plug-in that auto-issues EU AI Act Article 50 receipts for every model call.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "src",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts --clean"
  },
  "keywords": [
    "vercel",
    "ai-sdk",
    "ledgerproof",
    "eu-ai-act",
    "article-50"
  ],
  "author": "Veronica S. Dawkins <veronica@ledgerproofhq.io>",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vsdawkins-creator/ledgerproof-vercel-ai.git"
  },
  "homepage": "https://ledgerproofhq.io",
  "engines": {
    "node": ">=18"
  },
  "sideEffects": false,
  "dependencies": {
    "@ledgerproof/sdk": "^1.0.0"
  },
  "peerDependencies": {
    "ai": ">=3.0.0"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.4.0"
  }
}
